# Copy to .env.local and fill in real values.
# Restart `npm run dev` after editing this file — Vite reads env at startup.

# -------------------------------------------------------------
# Supabase
# -------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# -------------------------------------------------------------
# Tasks Module — switch between mock and live data.
#   true   → in-memory mock (default when SUPABASE_URL is missing)
#   false  → real Supabase (requires schema from
#            supabase/migrations/0001_tasks_schema.sql to be applied)
# -------------------------------------------------------------
VITE_USE_MOCK_TASKS=true

# -------------------------------------------------------------
# Service-role key — REQUIRED ONLY for the one-off provisioning
# script (scripts/provision-auth-users.mjs). NEVER expose this to
# the client; it bypasses RLS. Don't prefix with VITE_ — that
# would leak it into the bundle.
# -------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
